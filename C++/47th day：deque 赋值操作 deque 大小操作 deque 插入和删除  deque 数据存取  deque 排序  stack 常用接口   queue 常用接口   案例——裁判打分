#include <iostream>
#include <vector>
#include <algorithm>
#include <deque>
#include <string>
#include <ctime>
#include <algorithm>
using namespace std;

class Person{
    public:
        Person(double s, string n): name(n), score(s){} 
        string name;
        double score;
};

void createPerson(vector<Person> &v){
    string nameSeed = "ABCDE";

    for (int i = 0; i < 5; ++i){
        string name = "选手";
        name += nameSeed[i];

        double score = 0;
        Person p(score, name);
        //将创建的Person对象放入容器中
        v.push_back(p);
    }
}

void setScore(vector<Person> &v){
    for (vector<Person>::iterator it = v.begin(); it != v.end(); ++it){
        //将评委分数放入deque容器中
        deque<double> d;
        for (int i = 0; i < 10; ++i){
            double score = rand() % 41 + 60;// 60 ~ 100
            d.push_back(score);
        }

        //排序
        sort(d.begin(), d.end());
        //去除最高分和最低分
        d.pop_back();
        d.pop_front();

        //取平均分
        double sum = 0;
        for (deque<double>::iterator dit = d.begin(); dit != d.end(); ++dit){
            sum += *dit;//累加每个评委的分数
        }

        double avg = sum /= d.size();

        //将平均分赋值给选手身上
        it->score = avg;
    }
}

void showScore(vector<Person> &v){
    for (vector<Person>::iterator it = v.begin(); it != v.end(); ++it){
        cout << "name: " << it->name << " averge: " << it->score << endl;
    }
}

int main(){
    //随机数种子
    srand((unsigned int) time(NULL));

    //1.创建5名选手
    vector<Person> v;//存放选手的容器
    createPerson(v);

    //测试
    for (vector<Person>::iterator it = v.begin(); it != v.end(); ++it){
        cout << (*it).name << " " << (*it).score << endl;
    }

    //2.给5名选手打分
    setScore(v);

    //3.显示最后得分
    showScore(v);

    return 0;
}
