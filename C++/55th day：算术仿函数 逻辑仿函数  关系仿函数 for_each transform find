#include <iostream>
#include <vector>
#include <string>
#include <algorithm>
using namespace std;

//查找 内置数据类型
void test01(){
    vector<int> v;
    for (int i = 0; i < 10; ++i){
        v.push_back(i);
    }
    //查找容器中是否有 5 这个元素
    auto pos = find(v.begin(), v.end(), 5);
    if (pos == v.end()){
        cout << "didn't find" << endl;
    }
    else {
        cout << "found it: " << *pos << endl;
    }
}


//查找 自定义数据类型
class Person{
    public:
        Person(int a, string n): age(a) ,name(n){}
        int age;
        string name;

        //重载 ==, 让find知道如何进行对比
        bool operator==(const Person &p) const {  // 参数应该是引用
            return this->age == p.age && this->name == p.name;
        }
};

void test02(){
    vector<Person> v;
    Person p1(21, "aaa");
    Person p2(14, "bbb");
    Person p3(23, "ccc");
    Person p4(32, "ddd");

    v.push_back(p1);
    v.push_back(p2);
    v.push_back(p3);
    v.push_back(p4);

    auto pos = find(v.begin(), v.end(), p3);
    if (pos == v.end()){
        cout << "didn't find" << endl;
    }
    else {
        cout << "found it: \nname: " << pos->name << " age: " << pos->age << endl;
    }
}

int main(){

    test01();
    test02();

    return 0;
}




