#include <iostream>
#include <list>
using namespace std;

//lsit数据存取

void test01(){
    list<int> l1;
    l1.push_back(1);
    l1.push_back(2);
    l1.push_back(3);
    l1.push_back(4);

    //不可以用[]方式访问

    //l1.at(0) 不可用at方式访问list容器中的元素
    //list本质链表，并非连续线性空间存储数据，迭代器不支持随机访问

    cout << "第一个元素: " << l1.front() << endl;
    cout << "最后一个元素: " << l1.back() << endl;

    //验证迭代器不支持随机访问
    list<int>::iterator it = l1.begin();
    ++it;
    --it;// 支持双向
    
    // it = it + 1；报错
    // it = it + 3；报错
    // 不支持随机的访问
}

int main(){

    test01();

    return 0;
}





#include <iostream>
#include <list>
#include <algorithm>
using namespace std;

//list反转和排序
void printList(const list<int> &l){
    for (list<int>::const_iterator it = l.begin(); it != l.end(); ++it){
        cout << *it << " ";
    }
    cout << endl;
}

void test01(){
    //反转
    list<int> l1;
    
    l1.push_back(1);
    l1.push_back(2);
    l1.push_back(3);
    l1.push_back(4);

    cout << "反转前：";
    printList(l1);

    l1.reverse();
    cout << "反转后：";
    printList(l1);
}

bool myCompare(int i1, int i2){
    //降序  就让第一个数 ＞ 第二个数
    return i1 > i2;
}

//排序
void test02(){
    list<int> l2;
    
    l2.push_back(1);
    l2.push_back(1);
    l2.push_back(4);
    l2.push_back(5);
    l2.push_back(1);
    l2.push_back(4);

    cout << "排序前：";
    printList(l2);

    //所有不支持随机访问迭代器的容器，不可以用标准算法
    //sort(l2.begin(), l2.end());

    //不支持随机访问迭代器的容器，内部会提供一些对应的算法
    l2.sort();
    cout << "排序后：";
    printList(l2);

    l2.sort(myCompare);
    printList(l2);
}

int main(){

    test01();
    test02();

    return 0;
}






#include <iostream>
#include <list>
#include <string>
#include <algorithm>
using namespace std;

// list容器 排序案例 对于自定义数据类型 做排序

class Person{
    public:
        Person(string n, int a, int h): name(n), age(a), height(h){}

        string name;
        int age;
        int height;
};

//排序规则
bool comparePerson(const Person &p1, const Person &p2){
    //按照年龄 升序
    if (p1.age == p2.age){
        //年龄相同 按照身高降序排列
        return p1.height < p2.height;
    }
    return p1.age < p2.age;
}

void test01(){
    list<Person> l1;//创建容器

    //准备数据
    Person p1("鸢一折纸", 17, 152);
    Person p2("本条二亚", 30, 166);
    Person p3("时崎狂三", 25, 160);
    Person p4("四系乃  ", 13, 142);
    Person p5("五河琴里", 15, 142);
    Person p6("星宫六喰", 25, 161);

    //插入数据
    l1.push_back(p1);
    l1.push_back(p2);
    l1.push_back(p3);
    l1.push_back(p4);
    l1.push_back(p5);
    l1.push_back(p6);

    for (list<Person>::iterator it = l1.begin(); it != l1.end(); ++it){
        cout << "name: " << it->name << " \tage: " << it->age << " \theight: " << it->height << endl;
    }

    //排序
    cout << "排序后：" << endl;

    l1.sort(comparePerson);
    for (list<Person>::iterator it = l1.begin(); it != l1.end(); ++it){
        cout << "name: " << it->name << " \tage: " << it->age << " \theight: " << it->height << endl;
    }
}

int main(){

    test01();

    return 0;
}
