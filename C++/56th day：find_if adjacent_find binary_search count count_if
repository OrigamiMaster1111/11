#include <iostream>
#include <string>
#include <vector>
#include <algorithm>
using namespace std;

//1.查找内置数据类型
class GreaterFive{
    public:
        bool operator()(int val){
            return val > 5;
        }
};

void test01(){
    vector<int> v;
    for (int i = 0; i < 10; ++i){
        v.push_back(i);
    }
    auto pos = find_if(v.begin(), v.end(), GreaterFive());

    if (pos == v.end()){
        cout << "didn't find" << endl;
    }
    else {
        cout << "had find the number:" << *pos << endl;
    }
}

//查找自定义数据类型
class Person{
    public:
        Person(int a, string n): age(a), name(n) {}

        int age;
        string name;
};

class Greater14{
    public:
        bool operator()(Person &p){
            return p.age > 14;
        }
};

void test02(){
    vector<Person> v;
    Person p1(12,"a");
    Person p2(14,"c");
    Person p3(42,"g");
    Person p4(7,"h");
    Person p5(25,"j");

    v.push_back(p1);
    v.push_back(p2);
    v.push_back(p3);
    v.push_back(p4);
    v.push_back(p5);

    auto pos = find_if(v.begin(), v.end(), Greater14());
    if (pos == v.end()){
        cout << "didn't find" << endl;
    }
    else {
        cout << "had find the person: name is " << pos->name << ", age is " << pos->age << endl;
    }
}

int main(){

    test01();
    test02();

    return 0;
}




