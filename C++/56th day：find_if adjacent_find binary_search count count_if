#include <iostream>
#include <string>
#include <vector>
#include <algorithm>
using namespace std;

//统计内置数据类型
void test01(){
    vector<int> v;
    v.push_back(10);
    v.push_back(30);
    v.push_back(40);
    v.push_back(20);
    v.push_back(20);
    v.push_back(40);

    int num = count(v.begin(), v.end(), 40);

    cout << "40的个数: " << num << endl;
}

//自定义数据类型
class Person{
    public:
        Person(string n, int a): name(n), age(a) {}

        string name;
        int age;

        bool operator==(const Person &p){
            return this->age == p.age;
        }
};

void test02(){
    vector<Person> v;

    Person p1("a", 22);
    Person p2("b", 13);
    Person p3("c", 15);
    Person p4("d", 52);
    Person p5("e", 37);
    v.push_back(p1);
    v.push_back(p2);
    v.push_back(p3);
    v.push_back(p4);
    v.push_back(p5);

    Person p("f", 52);

    int num = count(v.begin(), v.end(), p);
    cout << "与f同岁的人数为" << num << endl;
}

int main(){

    test01();
    test02();

    return 0;
}





#include <iostream>
#include <string>
#include <vector>
#include <algorithm>
using namespace std;

//内置数据类型
class Greater20{
    public:
        bool operator()(int val){
            return val > 20;
        }
};

void test01(){
    vector<int> v;
    v.push_back(10);
    v.push_back(30);
    v.push_back(40);
    v.push_back(20);
    v.push_back(20);
    v.push_back(40);

    int num = count_if(v.begin(), v.end(), Greater20());
    cout << num << endl;
}

//自定义数据类型
class Person{
    public:
        Person(string n, int a): name(n), age(a) {}

        string name;
        int age;

        bool operator==(const Person &p){
            return this->age == p.age;
        }
};

class AgeGreater20{
    public:
        bool operator()(const Person &p){
            return p.age > 20;
        }
};

void test02(){
    vector<Person> v;

    Person p1("a", 22);
    Person p2("b", 13);
    Person p3("c", 15);
    Person p4("d", 52);
    Person p5("e", 37);
    v.push_back(p1);
    v.push_back(p2);
    v.push_back(p3);
    v.push_back(p4);
    v.push_back(p5);

    //统计大于20岁的人员个数
    int num = count_if(v.begin(), v.end(), AgeGreater20());
    cout << num << endl;
}

