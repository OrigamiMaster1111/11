#include <iostream>
#include <set>
using namespace std;

//set容器构造和赋值

void printSet(const set<int> &s){
    for (set<int>::const_iterator it = s.begin(); it != s.end(); ++it){
        cout << *it << " ";
    }
    cout << endl;
}

void test01(){
    set<int> s1;

    // 插入数据 只有insert方式
    s1.insert(10);
    s1.insert(30);
    s1.insert(20);
    s1.insert(70);
    s1.insert(40);
    s1.insert(40);

    //遍历
    //特点：1.自动排序 2.不允许重复
    printSet(s1);

    //拷贝构造
    set<int> s2(s1);
    printSet(s2);

    //赋值
    set<int> s3;
    s3 = s2;
    printSet(s3);
}

int main(){

    test01();

    return 0;
}



#include <iostream>
#include <set>
using namespace std;

void printSet(const set<int> &s){
    for (set<int>::const_iterator it = s.begin(); it != s.end(); ++it){
        cout << *it << " ";
    }
    cout << endl;
}

//大小
void test01(){
    set<int> s1;

    s1.insert(10);
    s1.insert(30);
    s1.insert(20);
    s1.insert(70);
    s1.insert(40);
    s1.insert(40);

    printSet(s1);

    //判断是否为为空
    if (s1.empty()){
        cout << "s1为空" << endl;
    }
    else {
        cout << "s1不为空" << endl;
        cout << "s1的大小" << s1.size() << endl;
    }
}

//交换
void test02(){
    set<int> s1;
    s1.insert(10);
    s1.insert(30);
    s1.insert(20);
    s1.insert(70);
    s1.insert(40);
    s1.insert(40);

    set<int> s2;
    s2.insert(100);
    s2.insert(300);
    s2.insert(200);
    s2.insert(700);
    s2.insert(400);
    s2.insert(400);

    cout << "Not change yet: " << endl;
    printSet(s1);
    printSet(s2);

    s1.swap(s2);
    cout << "Had changed: " << endl;
    printSet(s1);
    printSet(s2);
}

int main(){

    test01();
    test02();

    return 0;
}





#include <iostream>
#include <set>
using namespace std;

//set插入和删除

void printSet(const set<int> &s){
    for (set<int>::const_iterator it = s.begin(); it != s.end(); ++it){
        cout << *it << " ";
    }
    cout << endl;
}

void test01(){
    set<int> s1;
    s1.insert(1);
    s1.insert(2);
    s1.insert(5);
    s1.insert(4);
    s1.insert(3);
    printSet(s1);

    //删除
    s1.erase(s1.begin());
    printSet(s1);

    //删除重载版本
    s1.erase(30);
    printSet(s1);

    //清空
    s1.erase(s1.begin(), s1.end());// s1.clear(); 效果相同
    printSet(s1);
}

int main(){

    test01();

    return 0;
}





#include <iostream>
#include <set>
using namespace std;

//查找和统计

void test01(){
    //查找
    set<int> s1;
    s1.insert(1);
    s1.insert(2);
    s1.insert(5);
    s1.insert(4);
    s1.insert(3);
    
    set<int>::iterator pos = s1.find(3);
    if (pos != s1.end()){
        cout << "found the position: " << *pos << endl;
    }
    else {
        cout << "didn't find the number" << endl;
    }
}

void test02(){
    set<int> s1;
    s1.insert(1);
    s1.insert(2);
    s1.insert(5);
    s1.insert(4);
    s1.insert(3);
    s1.insert(3);

    //统计3的个数
    int num = s1.count(3);
    //对于set而言，结果只能为0或1
    cout << "num = " << num << endl;
}

int main(){

    test01();
    test02();

    return 0;
}





#include <iostream>
#include <set>
using namespace std;

//set与multiset的区别

void test01(){
    set<int> s1;
    pair<set<int>::iterator, bool> ret = s1.insert(10);

    if (ret.second){
        cout << "第一次插入成功" << endl;
    }
    else {
        cout << "第一次插入失败" << endl;
    }

    ret = s1.insert(10);
    if (ret.second){
        cout << "第二次插入成功" << endl;
    }
    else {
        cout << "第二次插入失败" << endl;
    }

    multiset<int> ms;
    //允许插入重复值
    ms.insert(10);
    ms.insert(10);

    for (multiset<int>::iterator it = ms.begin(); it != ms.end(); ++it){
        cout << *it << " ";
    }
    cout << endl;
}

int main(){

    test01();

    return 0;
}
